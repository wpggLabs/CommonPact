{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wpgglabs.github.io/CommonPact/profiles/pactrental/schemas/pactrental-profile.schema.json",
  "title": "PactRental canonical profile terms and evidence",
  "oneOf": [
    {
      "title": "PactRental canonical terms",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asset",
        "period",
        "handoff",
        "return",
        "price",
        "deposit",
        "permitted_use",
        "obligations",
        "cancellation",
        "condition_evidence",
        "accessibility"
      ],
      "properties": {
        "asset": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "reference",
            "category",
            "condition_summary"
          ],
          "properties": {
            "reference": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200
            },
            "category": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9._-]{1,63}$"
            },
            "condition_summary": {
              "type": "string",
              "maxLength": 2000
            }
          }
        },
        "period": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "starts_at",
            "ends_at"
          ],
          "properties": {
            "starts_at": {
              "type": "string",
              "format": "date-time"
            },
            "ends_at": {
              "type": "string",
              "format": "date-time"
            },
            "grace_minutes": {
              "type": "integer",
              "minimum": 0,
              "maximum": 10080
            }
          }
        },
        "handoff": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "method",
            "location_class"
          ],
          "properties": {
            "method": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9._-]{1,63}$"
            },
            "location_class": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9._-]{1,63}$"
            },
            "custodian": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200
            }
          }
        },
        "return": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "method",
            "deadline"
          ],
          "properties": {
            "method": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9._-]{1,63}$"
            },
            "deadline": {
              "type": "string",
              "format": "date-time"
            },
            "location_class": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9._-]{1,63}$"
            }
          }
        },
        "price": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "currency",
            "amount"
          ],
          "properties": {
            "currency": {
              "type": "string",
              "pattern": "^[A-Z]{3}$"
            },
            "amount": {
              "type": "string",
              "pattern": "^[0-9]+(?:\\.[0-9]{1,8})?$"
            },
            "provider": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200
            }
          }
        },
        "deposit": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required"
          ],
          "properties": {
            "required": {
              "type": "boolean"
            },
            "currency": {
              "type": "string",
              "pattern": "^[A-Z]{3}$"
            },
            "amount": {
              "type": "string"
            },
            "provider": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200
            },
            "release_conditions": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "permitted_use": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "obligations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "cancellation": {
          "type": "object"
        },
        "condition_evidence": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "method",
            "retention_days"
          ],
          "properties": {
            "method": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9._-]{1,63}$"
            },
            "retention_days": {
              "type": "integer",
              "minimum": 1,
              "maximum": 3650
            }
          }
        },
        "accessibility": {
          "type": "object"
        }
      }
    },
    {
      "title": "PactRental handoff or return evidence",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "asset_reference",
        "recorded_at",
        "condition_hashes",
        "accessories"
      ],
      "properties": {
        "kind": {
          "enum": [
            "handoff",
            "return"
          ]
        },
        "asset_reference": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "recorded_at": {
          "type": "string",
          "format": "date-time"
        },
        "condition_hashes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          }
        },
        "accessories": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "usage_reading": {
          "type": "string"
        },
        "exceptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  ]
}
